{
  "usesTypeScript": true,
  "usesStyledComponents": false,
  "usesCssModule": true,
  "cssPreprocessor": "css",
  "testLibrary": "None",
  "component": {
    "default": {
      "customTemplates": {
        "component": "templates/default/TemplateName.tsx",
        "style": "templates/default/index.module.css",
        "types": "templates/default/index.d.ts"
      },
      "path": "src/components/",
      "withStyle": true,
      "withTest": false,
      "withStory": false,
      "withLazy": false,
      "withTypes": true
    },
    "page": {
      "customTemplates": {
        "component": "templates/page/page.tsx",
        "style": "templates/page/index.module.css",
        "types": "templates/page/index.d.ts"
      },
      "path": "src/app/",
      "withStyle": true,
      "withTest": false,
      "withStory": false,
      "withLazy": false,
      "withTypes": true
    },
    "page-d": {
      "customTemplates": {
        "component": "templates/page-d/page.tsx",
        "style": "templates/page-d/index.module.css",
        "types": "templates/page-d/index.d.ts"
      },
      "customDirectory": "templatename/[id]",
      "path": "src/app",
      "withStyle": true,
      "withTest": false,
      "withStory": false,
      "withLazy": false,
      "withTypes": true
    }
  }
}